<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Music Player</title>
  <style>
  :root {
    --player-bg: rgba(255, 255, 255, 0.88);
    --player-text: #1e293b;
    --player-text-secondary: #64748b;
    --player-accent: #7db83d;
    --player-accent-hover: #6a9e34;
    --player-border: rgba(0,0,0,0.08);
    --player-progress-bg: #e2e8f0;
    --player-btn-bg: rgba(0,0,0,0.04);
    --player-btn-hover-bg: rgba(0,0,0,0.08);
    --player-btn-border: rgba(0,0,0,0.12);
    --player-scrollbar: #cbd5e1;
  }
  .player-panel.dark {
    --player-bg: rgba(15, 23, 42, 0.88);
    --player-text: #f1f5f9;
    --player-text-secondary: #94a3b8;
    --player-border: rgba(255,255,255,0.1);
    --player-progress-bg: #334155;
    --player-btn-bg: rgba(255,255,255,0.06);
    --player-btn-hover-bg: rgba(255,255,255,0.12);
    --player-btn-border: rgba(255,255,255,0.15);
    --player-scrollbar: #475569;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: transparent;
    overflow: hidden;
    font-family: system-ui, -apple-system, sans-serif;
  }
  .player-panel {
    width: 100vw;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--player-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    color: var(--player-text);
    padding: 24px;
    border-radius: 14px;
    transition: background 0.3s, color 0.3s;
  }
  .track-title {
    font-size: 0.95rem;
    margin-bottom: 16px;
    opacity: 0.85;
    font-weight: 500;
    text-align: center;
    word-break: break-word;
  }
  .controls {
    display: flex;
    gap: 18px;
    margin: 16px 0;
  }
  .controls button {
    background: var(--player-btn-bg);
    border: 1px solid var(--player-btn-border);
    color: var(--player-text);
    width: 42px;
    height: 42px;
    border-radius: 50%;
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  .controls button:hover {
    background: var(--player-btn-hover-bg);
    border-color: var(--player-accent);
    color: var(--player-accent);
  }
  .progress {
    width: 100%;
    margin: 12px 0;
    accent-color: var(--player-accent);
    height: 4px;
    border-radius: 2px;
    background: var(--player-progress-bg);
    cursor: pointer;
  }
  .progress::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--player-accent);
    cursor: pointer;
    box-shadow: 0 0 0 2px var(--player-bg);
  }
  .time {
    display: flex;
    justify-content: space-between;
    width: 100%;
    font-size: 0.75rem;
    opacity: 0.65;
    color: var(--player-text-secondary);
  }
  .playlist {
    width: 100%;
    margin-top: 14px;
    max-height: 120px;
    overflow-y: auto;
    border: 1px solid var(--player-border);
    border-radius: 8px;
    padding: 4px;
  }
  .playlist div {
    padding: 6px 10px;
    cursor: pointer;
    border-radius: 6px;
    opacity: 0.75;
    font-size: 0.8rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: 0.15s;
  }
  .playlist div.active {
    background: var(--player-accent);
    color: white;
    opacity: 1;
    font-weight: 500;
  }
  .playlist div:hover:not(.active) {
    background: var(--player-btn-hover-bg);
  }
  .playlist::-webkit-scrollbar {
    width: 4px;
  }
  .playlist::-webkit-scrollbar-track {
    background: transparent;
  }
  .playlist::-webkit-scrollbar-thumb {
    background: var(--player-scrollbar);
    border-radius: 4px;
  }
  </style>
</head>
<body>
  <div class="player-panel">
    <div class="track-title" id="trackTitle">未选择曲目</div>
    <div class="controls">
      <button id="prevBtn">⏮</button>
      <button id="playBtn">▶</button>
      <button id="nextBtn">⏭</button>
    </div>
    <input type="range" class="progress" id="progressBar" value="0" min="0" max="100" />
    <div class="time">
      <span id="currentTime">00:00</span>
      <span id="duration">00:00</span>
    </div>
    <div class="playlist" id="playlist"></div>
  </div>

  <script>
    // 替换成你 R2 上的真实 mp3 链接
    const playlist = [
      { title: "The Road Not Taken", url: "https://images.kusanali.top/hoyomix-and-aimer-the-road-not-taken.mp3" },
      { title: "La Vaguelette", url: "https://images.kusanali.top/hoyomix-la-vaguelette.mp3" },
      { title: "Surasthana Fantasia", url: "https://images.kusanali.top/hoyomix-surasthana-fantasia.mp3" },
      { title: "Passing Memories", url: "https://images.kusanali.top/zhangjie-and-hoyomix-passing-memories.mp3" }
    ];

    let currentIndex = 0;
    const audio = new Audio();
    let isPlaying = false;

    function assertElement<T extends Element>(element: T | null, name: string): T {
      if (!element) {
        throw new Error(`Music player element not found: ${name}`);
      }

      return element;
    }

    const playBtn = assertElement(document.getElementById('playBtn') as HTMLButtonElement | null, 'playBtn');
    const prevBtn = assertElement(document.getElementById('prevBtn') as HTMLButtonElement | null, 'prevBtn');
    const nextBtn = assertElement(document.getElementById('nextBtn') as HTMLButtonElement | null, 'nextBtn');
    const progressBar = assertElement(document.getElementById('progressBar') as HTMLInputElement | null, 'progressBar');
    const currentTimeEl = assertElement(document.getElementById('currentTime') as HTMLSpanElement | null, 'currentTime');
    const durationEl = assertElement(document.getElementById('duration') as HTMLSpanElement | null, 'duration');
    const trackTitle = assertElement(document.getElementById('trackTitle') as HTMLDivElement | null, 'trackTitle');
    const playlistEl = assertElement(document.getElementById('playlist') as HTMLDivElement | null, 'playlist');

    // 渲染播放列表
    playlist.forEach((song, idx) => {
      const div = document.createElement('div');
      div.textContent = song.title;
      div.addEventListener('click', () => loadAndPlay(idx));
      playlistEl.appendChild(div);
    });

    function updateActive() {
      [...playlistEl.children].forEach((el, i) => el.classList.toggle('active', i === currentIndex));
    }

    function loadAndPlay(index: number) {
      currentIndex = index;
      const song = playlist[currentIndex];
      audio.src = song.url;
      trackTitle.textContent = song.title;
      audio.play().then(() => {
        isPlaying = true;
        playBtn.textContent = '⏸';
        saveState();
      }).catch(console.warn);
      updateActive();
    }

    function togglePlay() {
      if (!audio.src) { loadAndPlay(0); return; }
      if (isPlaying) {
        audio.pause();
        playBtn.textContent = '▶';
      } else {
        audio.play();
        playBtn.textContent = '⏸';
      }
      isPlaying = !isPlaying;
      saveState();
    }

    function formatTime(s: number) {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m.toString().padStart(2, '0')}:${sec.toString().padStart(2, '0')}`;
    }

    audio.addEventListener('loadedmetadata', () => {
      durationEl.textContent = formatTime(audio.duration);
      progressBar.max = String(Math.floor(audio.duration));
    });
    audio.addEventListener('timeupdate', () => {
      progressBar.value = String(Math.floor(audio.currentTime));
      currentTimeEl.textContent = formatTime(audio.currentTime);
    });
    progressBar.addEventListener('input', () => {
      audio.currentTime = Number(progressBar.value);
    });
    audio.addEventListener('ended', () => {
      currentIndex = (currentIndex + 1) % playlist.length;
      loadAndPlay(currentIndex);
    });
    prevBtn.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + playlist.length) % playlist.length;
      loadAndPlay(currentIndex);
    });
    nextBtn.addEventListener('click', () => {
      currentIndex = (currentIndex + 1) % playlist.length;
      loadAndPlay(currentIndex);
    });
    playBtn.addEventListener('click', togglePlay);

    // 状态保存与恢复（解决页面跳转中断）
    function saveState() {
      const state = {
        currentIndex,
        currentTime: audio.currentTime,
        isPlaying: !audio.paused,
      };
      localStorage.setItem('musicPlayerState', JSON.stringify(state));
    }
    window.addEventListener('beforeunload', saveState);
    audio.addEventListener('pause', saveState);
    audio.addEventListener('ended', saveState);
    setInterval(saveState, 5000);

    // 恢复
    (function restore() {
      const saved = localStorage.getItem('musicPlayerState');
      if (!saved) return;
      try {
        const { currentIndex: idx, currentTime, isPlaying: wasPlaying } = JSON.parse(saved) as {
          currentIndex?: number;
          currentTime?: number;
          isPlaying?: boolean;
        };
        if (typeof idx === 'number' && playlist[idx]) {
          currentIndex = idx;
          const song = playlist[currentIndex];
          audio.src = song.url;
          trackTitle.textContent = song.title;
          updateActive();
          audio.addEventListener('loadedmetadata', () => {
            if (typeof currentTime === 'number') audio.currentTime = currentTime;
            if (wasPlaying) {
              audio.play().then(() => {
                playBtn.textContent = '⏸';
                isPlaying = true;
              }).catch(console.warn);
            }
          }, { once: true });
        }
      } catch (e) {}
    })();

    // 向父页面报告播放状态（用于控制小绿点）
    function notifyState() {
      window.parent.postMessage({
        type: 'playerState',
        isPlaying: !audio.paused,
        title: playlist[currentIndex]?.title,
      }, '*');
    }
    audio.addEventListener('play', notifyState);
    audio.addEventListener('pause', notifyState);
    audio.addEventListener('ended', notifyState);

    // 接收父页面发来的主题信息
    window.addEventListener('message', (event) => {
    if (event.data && event.data.type === 'themeChange') {
        const panel = document.querySelector('.player-panel');
      if (!panel) return;
        if (event.data.theme === 'dark') {
        panel.classList.add('dark');
        } else {
        panel.classList.remove('dark');
        }
    }
    });
  </script>
</body>
</html>