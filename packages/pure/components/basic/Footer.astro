---
import config from 'virtual:config'

import { Icon } from '../user'

const footerConf = config.footer
let social = footerConf.social || {}

// If the list does not contain rss, add it
if (!social.rss)
  social.rss = {
    label: 'RSS',
    url: '/rss.xml'
  }

const footerLink1 = footerConf.links?.filter(({ pos }) => pos === 1) || []
---

<footer class='mx-auto mb-5 mt-16 w-full'>
  <div class='border-t pt-5'>
    <div class='flex items-center gap-y-3 max-sm:flex-col sm:justify-between sm:gap-y-0'>
      <div class='flex items-center gap-x-4 gap-y-2 text-muted-foreground max-sm:flex-col'>
        { /* Position 1 */
          footerLink1.length > 0 && (
            <div>
              {footerLink1.map(({ title, link, style }, index) => (
                <>
                  <!- prettier-ignore -->
                  <a href={link} target='_blank' class={style}>{title}</a>
                  {index < footerLink1.length - 1 && <span class='mx-1'>•</span>}
                </>
              ))}
            </div>
          )
        }
        {/* Position 2 */}
        <div>
          {config.footer.year}
          {config.author}
          {
            footerConf.links && footerConf.links.length > 0 && (
              <>
                &
                <span>
                  {footerConf.links
                    .filter(({ pos }) => pos === 2)
                    .map(({ title, link, style }) => (
                      <span>
                        <a href={link} target='_blank' class={style}>{title}</a>
                      </span>
                    ))}
                </span>
              </>
            )
          }
        </div>
        {
          footerConf.credits && (
            <span>
              <a href='https://github.com/withastro/astro' target='_blank'>Astro</a>
              &
              <a href='https://github.com/cworld1/astro-theme-pure' target='_blank'>Pure</a>
              theme powered
            </span>
          )
        }
      </div>

      {/* Social Brands */}
      <div class='flex items-center gap-x-4'>
        {
          footerConf.social &&
            Object.entries(footerConf.social).map(([platform, { label, url }]) => (
              <a href={url} aria-label={label}>
                <Icon name={platform as keyof typeof footerConf.social} />
              </a>
            ))
        }
        <!-- 音乐播放器切换按钮 -->
        <button id="musicToggleBtn" aria-label="打开音乐播放器" style="background:none;border:none;cursor:pointer;position:relative;">
          <!-- 可以替换成别的 SVG 或继续用 Icon 组件，这里用内联 SVG 举例 -->
          <svg class="music-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18V5l12-2v13"/>
            <circle cx="6" cy="18" r="3"/>
            <circle cx="18" cy="16" r="3"/>
          </svg>
          <!-- 小绿点指示器 -->
          <span id="playingDot" style="display:none;position:absolute;top:-2px;right:-2px;width:8px;height:8px;background:#4ade80;border-radius:50%;border:1px solid white;"></span>
        </button>
      </div>
    </div>
  </div>
</footer>

<!-- 音乐播放器 iframe -->
<iframe
  id="musicFrame"
  src="/music"
  style="
    position: fixed;
    bottom: 80px;
    right: 20px;
    width: 320px;
    height: 420px;
    border: none;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
    z-index: 9999;
    display: none;
    background: transparent;
  "
  allow="autoplay"
></iframe>

<script>
  (function() {
    const btn = document.getElementById('musicToggleBtn');
    const frame = document.getElementById('musicFrame');
    const dot = document.getElementById('playingDot');

    if (!btn || !frame || !dot) return;

    let panelVisible = false;

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      panelVisible = !panelVisible;
      frame.style.display = panelVisible ? 'block' : 'none';
    });

    // 监听 iframe 发来的播放状态，控制小绿点
    window.addEventListener('message', (event) => {
      if (event.data && event.data.type === 'playerState') {
        if (event.data.isPlaying) {
          dot.style.display = 'block';
        } else {
          dot.style.display = 'none';
        }
      }
    });

    // 点击页面其他地方关闭面板（可选）
    document.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof Node)) return;
      if (panelVisible && frame && !frame.contains(target) && !btn.contains(target)) {
        panelVisible = false;
        frame.style.display = 'none';
      }
    });
  })();
</script>

<style>
  footer a {
    color: hsl(var(--foreground) / var(--un-text-opacity, 1));
    text-decoration: underline;
    font-weight: 500;
  }
  .music-icon {
  transition: stroke 0.2s ease;
  }
  button:hover .music-icon {
    stroke: #7db83d;
  }
</style>
